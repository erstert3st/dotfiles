{{ if eq .chezmoi.os "linux" -}}
{{ if or (eq .chezmoi.osRelease.id "debian") (eq .chezmoi.osRelease.id "ubuntu") (contains "debian" (get .chezmoi.osRelease "idLike" | default "")) (contains "ubuntu" (get .chezmoi.osRelease "idLike" | default "")) -}}
#!/bin/bash
# Rendered from .chezmoidata/packages.yaml - editing that file re-runs this script.
set -euo pipefail

{{ $cfg := .packages.debian -}}
{{ $desktop := and (hasKey . "desktop") .desktop -}}
{{ $wanted := concat .packages.common $cfg.extra (ternary (concat .packages.desktop $cfg.desktopExtra) (list) $desktop) -}}
{{ $pkgs := list -}}
{{ range $wanted -}}
{{   if not (has . $cfg.skip) -}}
{{     $pkgs = append $pkgs (get $cfg.rename . | default .) -}}
{{   end -}}
{{ end -}}

SUDO="sudo"
[ "$(id -u)" = 0 ] && SUDO=""
export DEBIAN_FRONTEND=noninteractive

$SUDO apt-get update
$SUDO apt-get install -y --no-install-recommends \
{{- range $pkgs | uniq }}
    {{ . | quote }} \
{{- end }}

{{ end -}}
{{ end -}}
