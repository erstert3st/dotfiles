{{ if eq .chezmoi.os "linux" -}}
{{ if or (eq .chezmoi.osRelease.id "arch") (contains "arch" (get .chezmoi.osRelease "idLike" | default "")) -}}
#!/bin/bash
# Rendered from .chezmoidata/packages.yaml - editing that file re-runs this script.
set -euo pipefail

{{ $cfg := .packages.arch -}}
{{ $desktop := and (hasKey . "desktop") .desktop -}}
{{ $wanted := concat .packages.common $cfg.extra (ternary (concat .packages.desktop $cfg.desktopExtra) (list) $desktop) -}}
{{ $pkgs := list -}}
{{ range $wanted -}}
{{   if not (has . $cfg.skip) -}}
{{     $pkgs = append $pkgs (get $cfg.rename . | default .) -}}
{{   end -}}
{{ end -}}

SUDO="sudo"
[ "$(id -u)" = 0 ] && SUDO=""

$SUDO pacman -S --needed --noconfirm \
{{- range $pkgs | uniq }}
    {{ . | quote }} \
{{- end }}

{{ $aur := ternary (concat $cfg.aur $cfg.aurDesktop) $cfg.aur $desktop -}}
{{ if $aur -}}
if command -v paru >/dev/null 2>&1; then
    paru -S --needed --noconfirm \
{{- range $aur | uniq }}
        {{ . | quote }} \
{{- end }}

else
    echo "paru not found - skipping AUR packages:{{ range $aur | uniq }} {{ . }}{{ end }}"
fi
{{ end -}}
{{ end -}}
{{ end -}}
