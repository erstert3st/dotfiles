{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Rendered from .chezmoidata/packages.yaml - editing that file re-runs this script.
set -euo pipefail

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ if and (hasKey . "desktop") .desktop -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ end -}}
EOF
{{ end -}}
