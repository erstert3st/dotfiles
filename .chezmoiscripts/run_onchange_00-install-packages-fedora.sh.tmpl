{{ if eq .chezmoi.os "linux" -}}
{{ if or (eq .chezmoi.osRelease.id "fedora") (eq .chezmoi.osRelease.id "rhel") (eq .chezmoi.osRelease.id "centos") (contains "rhel" (.chezmoi.osRelease.idLike | default "")) (contains "fedora" (.chezmoi.osRelease.idLike | default "")) -}}
#!/bin/bash
# Rendered from .chezmoidata/packages.yaml - editing that file re-runs this script.
set -euo pipefail

{{ $cfg := .packages.fedora -}}
{{ $desktop := and (hasKey . "desktop") .desktop -}}
{{ $wanted := concat .packages.common $cfg.extra (ternary (concat .packages.desktop $cfg.desktopExtra) (list) $desktop) -}}
{{ $pkgs := list -}}
{{ range $wanted -}}
{{   if not (has . $cfg.skip) -}}
{{     $pkgs = append $pkgs (get $cfg.rename . | default .) -}}
{{   end -}}
{{ end -}}

SUDO="sudo"
[ "$(id -u)" = 0 ] && SUDO=""

$SUDO dnf install -y \
{{- range $pkgs | uniq }}
    {{ . | quote }} \
{{- end }}

{{ end -}}
{{ end -}}
