{
  "agentPushNotifEnabled": true,
  "autoUpdatesChannel": "latest",
  "editorMode": "normal",
  "effortLevel": "xhigh",
  "enabledPlugins": {},
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    }
  },
{{- $agentHook := joinPath .chezmoi.homeDir ".claude/hooks/herdr-agent-state.sh" }}
{{- $titleHook := joinPath .chezmoi.homeDir ".claude/hooks/herdr-claude-session-title.sh" }}
{{- $hasAgent := stat $agentHook }}
{{- $hasTitle := stat $titleHook }}
{{- if or $hasAgent $hasTitle }}
  "hooks": {
    "SessionStart": [
{{- if $hasAgent }}
      {
        "hooks": [
          {
            "command": "bash '{{ $agentHook }}' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }{{ if $hasTitle }},{{ end }}
{{- end }}
{{- if $hasTitle }}
      {
        "hooks": [
          {
            "command": "sh '{{ $titleHook }}'",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
{{- end }}
    ]{{ if $hasTitle }},
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "sh '{{ $titleHook }}'",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "sh '{{ $titleHook }}'",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]{{ end }}
  },
{{- end }}
  "language": "German",
  "permissions": {
    "allow": [
      "mcp__claude-in-chrome__navigate",
      "mcp__claude-in-chrome__read_network_requests",
      "mcp__claude-in-chrome__read_console_messages",
      "mcp__claude-in-chrome__tabs_create_mcp",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__browser_batch"
    ]
  },
  "preferredNotifChannel": "kitty",
  "remoteControlAtStartup": false,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "teammateMode": "auto",
  "tui": "default"
}
